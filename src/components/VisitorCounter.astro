---
// src/components/VisitorCounter.astro
---
<div id="visitor-counter" class="visitor-counter">
  <span class="label">VISITOR #</span>
  <span id="count" class="count">Loading...</span>
</div>

<style>
  .visitor-counter {
    position: fixed;
    bottom: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #444;
    border-radius: 3px;
    padding: 5px 15px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    color: #eee;
    backdrop-filter: blur(5px);
    z-index: 1000;
  }
  .label {
    color: #888;
  }
  .count {
    color: #00ff00;
    font-weight: bold;
  }
</style>

<script>
  async function getVisitorCount() {
    try {
      const response = await fetch('/.netlify/functions/visitor_counter');
      if (!response.ok) throw new Error('Failed to fetch count');
      const data = await response.json();
      const countEl = document.getElementById('count');
      if (countEl) {
        countEl.textContent = data.count.toString().padStart(5, '0');
      }
    } catch (error) {
      console.error("Visitor Counter Error:", error);
      const countEl = document.getElementById('count');
      if (countEl) {
        countEl.textContent = 'Error';
      }
    }
  }

  document.addEventListener('astro:page-load', getVisitorCount);
</script>
