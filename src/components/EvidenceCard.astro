---
const { finding } = Astro.props;

// Format absolute timestamp for forensic display
const dateObj = new Date(finding.absolute_timestamp);
const formattedTime = dateObj.toLocaleTimeString('en-US', { 
  hour12: true, 
  hour: '2-digit', 
  minute: '2-digit', 
  second: '2-digit' 
});
const formattedDate = dateObj.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
---
<div class={`evidence-card ${finding.risk.toLowerCase()}`}>
  <div class="header">
    <div class="title-group">
      <span class="evidence-tag">TARGET EVIDENCE</span>
      <h2 class="id">{finding.evidence_name || `EV-${finding.folder}-${finding.offset_seconds}`}</h2>
    </div>
    <div class="risk-info">
      <span class="risk-badge">{finding.risk}</span>
      <span class="reason-badge">{finding.reason}</span>
    </div>
  </div>

  <!-- WaveSurfer Player Section -->
  <div class="player-container">
    <div id={`waveform-${finding.evidence_id.replace(/\W/g, '-')}`} class="waveform"></div>
    <div class="controls">
      <button class="play-btn" data-id={`${finding.evidence_id.replace(/\W/g, '-')}`} data-url={`/data/${finding.folder}/${finding.audio_file}`}>PLAY EVIDENCE</button>
      <div class="source-info">
        <span class="source-label">LOG SOURCE:</span>
        <span class="source-val">{finding.source_file} @ {finding.offset_seconds}s</span>
      </div>
    </div>
  </div>

  <div class="forensic-grid">
    <div class="img-box">
      <div class="img-label">IMAGE 01 // WAVEFORM [BRICK]</div>
      <img src={`/data/${finding.folder}/${finding.image_waveform}`} alt="Waveform" />
    </div>
    <div class="img-box">
      <div class="img-label">IMAGE 02 // SPECTROGRAM [MESS]</div>
      <img src={`/data/${finding.folder}/${finding.image_spectrogram}`} alt="Spectrogram" />
    </div>
    <div class="img-box">
      <div class="img-label">IMAGE 03 // CHAOS [SHRED]</div>
      <img src={`/data/${finding.folder}/${finding.image_chaos}`} alt="Chaos" />
    </div>
    <div class="img-box">
      <div class="img-label">IMAGE 04 // PITCH TRACK [SHRIEK]</div>
      <img src={`/data/${finding.folder}/${finding.image_pitch}`} alt="Pitch" />
    </div>
  </div>

  <details class="expert-analysis" open={finding.is_forsure}>
    <summary>
      <span class="summary-icon">◈</span>
      EXPERT ANALYSIS & VERDICT
      <span class="status-indicator">{finding.is_forsure ? 'CRITICAL' : 'ROUTINE'}</span>
    </summary>
    <div class="analysis-content">
      <p class="verdict">{finding.expert_analysis.verdict}</p>
      <div class="breakdown-grid">
        <div class="breakdown-item">
          <span class="breakdown-label">METHODOLOGY [WHY]</span>
          <p>{finding.expert_analysis.why}</p>
        </div>
        <div class="breakdown-item">
          <span class="breakdown-label">FORENSIC PROOF</span>
          <p>{finding.expert_analysis.proof}</p>
        </div>
      </div>
    </div>
  </details>

  {/* Triangulation Section - All 3 Models */}
  <details class="triangulation-analysis" open={finding.is_forsure}>
    <summary>
      <span class="summary-icon">◈</span>
      MULTI-MODEL TRIANGULATION
      <span class="model-badge">VGGish + BEATs + CLAP</span>
    </summary>
    <div class="triangulation-content">
      <p class="triangulation-desc">
        Convergence analysis across three independent AI models. When all three flag the same 
        timestamp with high scores, confidence increases exponentially.
      </p>
      
      <div class="tri-grid">
        {/* VGGish */}
        <div class="tri-panel vggish">
          <h4>01 // VGGish</h4>
          <p class="tri-type">Google (2017) - Raw Salience</p>
          <div class="tri-metric">
            <span>Embedding:</span>
            <strong>128-dim</strong>
          </div>
          <div class="tri-metric">
            <span>Function:</span>
            <strong>Acoustic Novelty</strong>
          </div>
          <p class="tri-note">Detects statistically salient deviations from background audio.</p>
        </div>
        
        {/* BEATs */}
        <div class="tri-panel beats">
          <h4>02 // BEATs</h4>
          <p class="tri-type">Microsoft (2023) - Deep Structure</p>
          <div class="tri-metric">
            <span>Embedding:</span>
            <strong>768-dim</strong>
          </div>
          <div class="tri-metric">
            <span>Function:</span>
            <strong>Temporal Anomaly</strong>
          </div>
          <p class="tri-note">Self-supervised transformer captures subtle pattern changes.</p>
        </div>
        
        {/* CLAP */}
        <div class="tri-panel clap">
          <h4>03 // LAION-CLAP</h4>
          <p class="tri-type">LAION-AI (2023) - Semantics</p>
          <div class="tri-metric">
            <span>Embedding:</span>
            <strong>Text-Audio</strong>
          </div>
          <div class="tri-metric">
            <span>Function:</span>
            <strong>Zero-Shot Match</strong>
          </div>
          <p class="tri-note">Matches audio to human language descriptions.</p>
        </div>
      </div>
      
      {/* CLAP Heatmap */}
      <div class="clap-heatmap">
        <h4>LAION-CLAP Similarity Heatmap</h4>
        <img src={`/data/${finding.folder}/clap/laion_clap_timeline.png`} alt="CLAP analysis" />
      </div>
    </div>
  </details>

  {/* LAION-CLAP Analysis Section */}
  {finding.laion_clap && (
    <details class="laion-clap-analysis">
      <summary>
        <span class="summary-icon">◉</span>
        LAION-CLAP SEMANTIC ANALYSIS
        <span class="model-badge">AI CROSS-VALIDATION</span>
      </summary>
      <div class="laion-content">
        <p class="laion-description">{finding.laion_clap.model} — {finding.laion_clap.description}</p>
        
        <div class="laion-grid">
          <div class="laion-matches">
            <h4>TOP SEMANTIC MATCHES</h4>
            <div class="matches-list">
              {finding.laion_clap.top_matches.map((match, idx) => (
                <div class="match-item">
                  <span class="match-rank">#{idx + 1}</span>
                  <span class="match-desc">{match.description}</span>
                  <span class="match-score">{(match.similarity * 100).toFixed(1)}%</span>
                </div>
              ))}
            </div>
          </div>
          
          <div class="laion-findings">
            <h4>KEY FINDINGS</h4>
            <ul>
              {finding.laion_clap.key_findings.map(finding => (
                <li>{finding}</li>
              ))}
            </ul>
          </div>
        </div>
        
        <div class="laion-images">
          <div class="laion-img-box">
            <div class="img-label">EVENT MATCHES</div>
            <img src={`/data/${finding.folder}/${finding.laion_clap.images.event_matches}`} alt="LAION-CLAP Event Matches" />
          </div>
          <div class="laion-img-box">
            <div class="img-label">SIMILARITY HEATMAP</div>
            <img src={`/data/${finding.folder}/${finding.laion_clap.images.similarity_heatmap}`} alt="LAION-CLAP Similarity Heatmap" />
          </div>
        </div>
      </div>
    </details>
  )}

  <div class="metadata-grid">
    <div class="meta-section">
      <h3>ACOUSTIC FEATURES</h3>
      <div class="meta-row">
        <span>DETECTION TYPE</span>
        <strong>SPIKE</strong>
      </div>
      <div class="meta-row">
        <span>RMS VALUE</span>
        <strong>{finding.rms}</strong>
      </div>
      <div class="meta-row">
        <span>SPECTRAL CENTROID</span>
        <strong>{finding.centroid} HZ</strong>
      </div>
      <div class="meta-row">
        <span>HIGH-BAND ENERGY</span>
        <strong>{finding.highband_ratio}</strong>
      </div>
    </div>
    <div class="meta-section">
      <h3>CHAIN OF CUSTODY</h3>
      <div class="meta-row">
        <span>EVIDENCE ID</span>
        <strong class="mono">{finding.evidence_id}</strong>
      </div>
      <div class="meta-row">
        <span>MD5 HASH</span>
        <strong class="hash">{finding.md5}</strong>
      </div>
      <div class="meta-row">
        <span>SOURCE TIMESTAMP</span>
        <strong class="mono">{formattedDate} // {formattedTime}</strong>
      </div>
    </div>
  </div>
</div>

<style>
  .evidence-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: 120px; /* Increased spacing */
    padding: 60px; /* More internal breathing room */
    position: relative;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.8);
    border-bottom: 4px solid var(--border); /* Solid bottom border */
  }

  .evidence-card::before {
    content: '--- FORENSIC BOUNDARY ---';
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: #444;
    letter-spacing: 5px;
  }

  .evidence-card::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 100px;
    background: linear-gradient(225deg, transparent 49%, var(--border) 50%, transparent 51%);
    opacity: 0.1;
  }

  .evidence-card.red { border-top: 4px solid var(--accent-red); }
  .evidence-card.yellow { border-top: 4px solid var(--accent-yellow); }

  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
  
  .evidence-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--accent-cyan); letter-spacing: 3px; display: block; margin-bottom: 5px; }
  h2.id { font-size: 1.8rem; margin: 0; font-weight: 700; color: #fff; letter-spacing: -0.5px; }

  .risk-info { display: flex; gap: 10px; }
  .risk-badge { 
    background: rgba(255, 62, 62, 0.1); color: var(--accent-red); 
    padding: 5px 15px; border-radius: 2px; font-weight: bold; border: 1px solid rgba(255, 62, 62, 0.2);
    font-size: 0.8rem; letter-spacing: 1px;
  }
  .yellow .risk-badge { background: rgba(255, 184, 0, 0.1); color: var(--accent-yellow); border-color: rgba(255, 184, 0, 0.2); }
  
  .reason-badge {
    background: #1a1a1a; color: #aaa; padding: 5px 15px; border-radius: 2px;
    font-size: 0.8rem; border: 1px solid #333; font-family: 'JetBrains Mono', monospace;
  }

  .player-container { 
    background: #000; padding: 25px; border: 1px solid #1a1a1a; border-radius: 4px; margin-bottom: 30px;
  }
  .controls { display: flex; align-items: center; gap: 30px; margin-top: 15px; }
  .play-btn {
    background: transparent; color: #fff; border: 1px solid var(--accent-red); padding: 10px 25px;
    border-radius: 2px; cursor: pointer; font-weight: bold; font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem; transition: all 0.2s;
  }
  .play-btn:hover { background: var(--accent-red); color: #000; box-shadow: 0 0 20px rgba(255, 62, 62, 0.3); }

  .source-info { display: flex; flex-direction: column; }
  .source-label { font-size: 0.6rem; color: #555; letter-spacing: 1px; }
  .source-val { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #888; }

  .forensic-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 40px;
  }
  .img-box { position: relative; }
  .img-label { 
    position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.8);
    color: var(--accent-cyan); font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
    padding: 4px 8px; border-radius: 2px; border: 1px solid rgba(0,240,255,0.2);
  }
  .img-box img { width: 100%; border-radius: 2px; border: 1px solid #1a1a1a; filter: grayscale(0.2) contrast(1.1); }
  .img-box img:hover { filter: grayscale(0) contrast(1.2); cursor: crosshair; }

  .expert-analysis {
    background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 4px; margin-bottom: 40px;
  }
  .expert-analysis summary {
    padding: 20px; color: #fff; cursor: pointer; font-weight: bold;
    font-family: 'JetBrains Mono', monospace; letter-spacing: 2px;
    display: flex; align-items: center; justify-content: space-between;
    transition: background 0.2s; user-select: none;
  }
  .expert-analysis summary:hover { background: #111; }
  .expert-analysis summary::-webkit-details-marker { display: none; }
  
  .summary-icon { color: var(--accent-red); margin-right: 15px; font-size: 1.2rem; }
  .status-indicator { font-size: 0.6rem; background: var(--border); padding: 4px 10px; border-radius: 2px; color: #aaa; }
  .red .status-indicator { background: rgba(255, 62, 62, 0.2); color: var(--accent-red); }

  .analysis-content { padding: 30px; border-top: 1px solid #1a1a1a; }
  .verdict { font-size: 1.4rem; color: #fff; margin-top: 0; margin-bottom: 25px; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px; font-weight: bold; }
  
  .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .breakdown-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--accent-cyan); display: block; margin-bottom: 10px; letter-spacing: 2px; }
  .breakdown-item p { color: var(--text-main); font-size: 0.95rem; margin: 0; text-align: justify; }

  .metadata-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; padding-top: 30px; border-top: 1px solid #1a1a1a; }
  h3 { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--text-dim); margin-bottom: 25px; letter-spacing: 3px; }
  
  .meta-row { display: flex; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.02); padding-bottom: 5px; }
  .meta-row span { font-size: 0.7rem; color: #666; font-family: 'JetBrains Mono', monospace; }
  .meta-row strong { font-size: 0.85rem; color: #fff; }
  .meta-row strong.hash { font-size: 0.7rem; color: #555; font-family: 'JetBrains Mono', monospace; }
  .meta-row strong.mono { font-family: 'JetBrains Mono', monospace; color: var(--accent-cyan); }

  /* LAION-CLAP Section Styles */
  .laion-clap-analysis {
    background: linear-gradient(135deg, rgba(138, 43, 226, 0.05) 0%, rgba(0, 0, 0, 0.3) 100%);
    border: 1px solid rgba(138, 43, 226, 0.3);
    border-radius: 4px;
    margin-bottom: 40px;
    overflow: hidden;
  }
  
  .laion-clap-analysis summary {
    padding: 20px;
    color: #fff;
    cursor: pointer;
    font-weight: bold;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s;
    user-select: none;
    background: rgba(138, 43, 226, 0.1);
  }
  
  .laion-clap-analysis summary:hover { 
    background: rgba(138, 43, 226, 0.15); 
  }
  
  .laion-clap-analysis summary::-webkit-details-marker { display: none; }
  
  .laion-clap-analysis .summary-icon { 
    color: #8a2be2; 
    margin-right: 15px; 
    font-size: 1.2rem; 
  }
  
  .model-badge {
    font-size: 0.6rem;
    background: rgba(138, 43, 226, 0.2);
    padding: 4px 10px;
    border-radius: 2px;
    color: #c084fc;
    border: 1px solid rgba(138, 43, 226, 0.3);
  }
  
  .laion-content {
    padding: 30px;
    border-top: 1px solid rgba(138, 43, 226, 0.2);
  }
  
  .laion-description {
    font-size: 0.9rem;
    color: #888;
    margin: 0 0 20px 0;
    font-style: italic;
  }
  
  .laion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 30px;
  }
  
  .laion-matches h4,
  .laion-findings h4 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: #c084fc;
    margin: 0 0 15px 0;
    letter-spacing: 2px;
  }
  
  .matches-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  .match-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 4px;
    border-left: 3px solid #8a2be2;
  }
  
  .match-rank {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: #8a2be2;
    min-width: 25px;
  }
  
  .match-desc {
    flex: 1;
    font-size: 0.8rem;
    color: #ccc;
  }
  
  .match-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #c084fc;
    font-weight: bold;
  }
  
  .laion-findings ul {
    margin: 0;
    padding-left: 20px;
  }
  
  .laion-findings li {
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  
  .laion-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  
  .laion-img-box {
    position: relative;
  }
  
  .laion-img-box .img-label {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(138, 43, 226, 0.9);
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    padding: 4px 8px;
    border-radius: 2px;
    z-index: 10;
  }
  
  .laion-img-box img {
    width: 100%;
    border-radius: 4px;
    border: 1px solid rgba(138, 43, 226, 0.3);
  }

  /* Triangulation Section */
  .triangulation-analysis {
    background: linear-gradient(135deg, rgba(0, 240, 255, 0.05) 0%, rgba(0, 0, 0, 0.3) 100%);
    border: 1px solid rgba(0, 240, 255, 0.3);
    border-radius: 4px;
    margin-bottom: 40px;
  }

  .triangulation-analysis summary {
    padding: 20px;
    color: #fff;
    cursor: pointer;
    font-weight: bold;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0, 240, 255, 0.1);
  }

  .triangulation-content {
    padding: 30px;
    border-top: 1px solid rgba(0, 240, 255, 0.2);
  }

  .triangulation-desc {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 30px;
    font-style: italic;
  }

  .tri-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }

  .tri-panel {
    background: rgba(0, 0, 0, 0.3);
    padding: 20px;
    border-radius: 4px;
    border-left: 4px solid;
  }

  .tri-panel.vggish { border-left-color: #ff6b6b; }
  .tri-panel.beats { border-left-color: #4ecdc4; }
  .tri-panel.clap { border-left-color: #9b59b6; }

  .tri-panel h4 {
    margin: 0 0 5px 0;
    color: #fff;
    font-size: 0.9rem;
  }

  .tri-type {
    color: var(--text-dim);
    font-size: 0.75rem;
    margin: 0 0 15px 0;
    font-family: 'JetBrains Mono', monospace;
  }

  .tri-metric {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 0.85rem;
  }

  .tri-metric span { color: var(--text-dim); }
  .tri-metric strong { color: #fff; }

  .tri-note {
    color: var(--text-dim);
    font-size: 0.8rem;
    margin-top: 15px;
    line-height: 1.4;
  }

  .clap-heatmap {
    background: #000;
    padding: 20px;
    border-radius: 4px;
    border: 1px solid #333;
  }

  .clap-heatmap h4 {
    color: var(--accent-cyan);
    margin: 0 0 15px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .clap-heatmap img {
    width: 100%;
    border-radius: 4px;
  }

  @media (max-width: 900px) {
    .tri-grid { grid-template-columns: 1fr; }
  }
</style>
