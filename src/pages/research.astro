---
import Layout from '../layouts/Layout.astro';

const references = [
  {
    filename: "PIIS096098221500737X.pdf",
    title: "Human Screams Occupy a Privileged Niche in the Communication Soundscape",
    authors: "Arnal, Flinker, et al.",
    journal: "Current Biology (2015)",
    doi: "10.1016/j.cub.2015.06.010",
    category: "Primary: Acoustic Roughness",
    application: "Established the 30-150 Hz modulation band as the biological signature of human distress. Our roughness analysis extracts this exact frequency band to identify terror screams vs. other vocalizations."
  },
  {
    filename: "nihms709805.pdf",
    title: "Roughness and the Sound of Screams",
    authors: "Arnal & Poeppel",
    journal: "NIHMS / NYU Research",
    category: "Primary: Acoustic Roughness",
    application: "Validates roughness as a unique perceptual attribute of screams. We apply this by computing spectral flatness in the 30-150 Hz band to quantify 'rough' acoustic texture indicative of distress."
  },
  {
    filename: "Forensic_Analysis_of_the_Audibility_of_Female_Scre.pdf",
    title: "Forensic Analysis of the Audibility of Female Screams",
    authors: "Forensic Acoustics Research",
    journal: "Journal of Forensic Sciences",
    category: "Forensic Application",
    application: "Provides courtroom-admissible standards for scream audibility analysis. Informed our threshold criteria for determining when distant/distorted vocalizations constitute identifiable distress signals."
  },
  {
    filename: "formative-2020-6-e18279.pdf",
    title: "Audio Forensics: Voice Analysis and Speaker Identification",
    authors: "Formative Research Team",
    journal: "Formative (2020)",
    category: "Forensic Methodology",
    application: "Established protocols for forensic voice analysis including spectral centroid tracking and formant analysis. Our pitch track (Image 04) and centroid measurements follow these standards."
  },
  {
    filename: "nandwana14_interspeech.pdf",
    title: "Automatic Scream Detection in Noisy Environments",
    authors: "Nandwana, et al.",
    journal: "INTERSPEECH (2014)",
    category: "AI Detection Methods",
    application: "Demonstrates machine learning approaches to scream detection in low-SNR conditions. Informed our multi-model ensemble approach using VGGish + BEATs + CLAP for robust detection."
  },
  {
    filename: "Sound Pressure Spikes & Rooms - Acoustic Sciences Corporation.pdf",
    title: "Sound Pressure Spikes & Room Acoustics",
    authors: "Acoustic Sciences Corporation",
    journal: "Technical White Paper",
    category: "Acoustic Physics",
    application: "Explains impulse response and pressure spike propagation in enclosed spaces. Essential for understanding how impact events (door slams, thuds) manifest in distant microphone recordings."
  }
];
---

<Layout title="Research & References | 1112 King Rd">
  <div class="container">
    <header class="page-header">
      <h1 class="glitch" data-text="RESEARCH & REFERENCES">RESEARCH & REFERENCES</h1>
      <p class="subtitle">Peer-Reviewed Foundations of Our Forensic Methodology</p>
    </header>

    <section class="intro">
      <p class="lead">
        This analysis is built upon established peer-reviewed research in acoustic forensics, 
        psychoacoustics, and machine learning. Each paper below directly informed our 
        methodological choices — from the 30-150 Hz roughness band to the multi-model 
        ensemble approach for validation.
      </p>
    </section>

    <!-- Application Summary -->
    <section class="application-section">
      <h2>How Research Informs Our Analysis</h2>
      
      <div class="application-grid">
        <div class="app-card">
          <h3>01 // Roughness Analysis</h3>
          <p class="paper">Arnal et al. (2015), Arnal & Poeppel</p>
          <p class="desc">
            The <strong>30-150 Hz modulation band</strong> identified by Arnal as unique to 
            human screams forms the core of our acoustic roughness analysis. We extract the 
            amplitude envelope via Hilbert transform and compute Power Spectral Density (PSD) 
            in this specific band.
          </p>
          <p class="threshold">
            <strong>Our Thresholds:</strong><br/>
            Roughness &gt; 20% = Suspicious (biological distress)<br/>
            Roughness &gt; 40% = Forensic proof of terror scream
          </p>
        </div>

        <div class="app-card">
          <h3>02 // Spectral Feature Extraction</h3>
          <p class="paper">Formative (2020), Nandwana et al. (2014)</p>
          <p class="desc">
            Forensic voice analysis standards for speaker identification and scream detection 
            in noisy environments. We apply these protocols through four indicators: BRICK 
            (waveform energy), MESS (spectrogram blur), SHRED (spectral flatness/roughness), 
            and SHRIEK (pitch track/centroid).
          </p>
          <p class="threshold">
            <strong>Our Indicators:</strong><br/>
            Centroid &gt; 1500 Hz = High-pitch shriek<br/>
            Flatness &gt; 15% = Chaotic/non-tonal
          </p>
        </div>

        <div class="app-card">
          <h3>03 // Multi-Model Validation</h3>
          <p class="paper">INTERSPEECH Scream Detection Literature</p>
          <p class="desc">
            Research on ensemble methods for scream detection in low-SNR conditions informed 
            our <strong>triangulation approach</strong>. Rather than relying on a single model, 
            we use three orthogonal systems (VGGish, BEATs, CLAP) and require convergence 
            for high-confidence detections.
          </p>
          <p class="threshold">
            <strong>Convergence Criteria:</strong><br/>
            2+ models agree = Medium confidence<br/>
            All 3 models agree = High confidence
          </p>
        </div>

        <div class="app-card">
          <h3>04 // Impact Acoustics</h3>
          <p class="paper">Acoustic Sciences Corporation</p>
          <p class="desc">
            Understanding of impulse response and pressure spike propagation explains how 
            mechanical impacts (door slams, thuds) manifest in distant recordings. Our 
            <strong>crest factor analysis</strong> (>15 dB threshold) identifies these 
            structural events that often precede distress vocalizations.
          </p>
          <p class="threshold">
            <strong>Impact Detection:</strong><br/>
            Crest Factor &gt; 15 dB = Physical impact<br/>
            Sudden onset + decay pattern
          </p>
        </div>
      </div>
    </section>

    <!-- Reference List -->
    <section class="references-section">
      <h2>Full Reference Library</h2>
      <p class="section-note">
        Click any reference to download the full PDF. These papers represent the scientific 
        foundation for every methodological choice in our analysis.
      </p>

      <div class="ref-list">
        {references.map((ref, idx) => (
          <div class="ref-item">
            <div class="ref-number">{String(idx + 1).padStart(2, '0')}</div>
            <div class="ref-content">
              <div class="ref-header">
                <h3>{ref.title}</h3>
                <span class="ref-category">{ref.category}</span>
              </div>
              <p class="ref-meta">
                {ref.authors} | {ref.journal}
                {ref.doi && <span class="doi">DOI: {ref.doi}</span>}
              </p>
              <p class="ref-application">
                <strong>Application:</strong> {ref.application}
              </p>
              <a 
                href={`/research/${ref.filename}`} 
                class="download-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="icon">↓</span>
                Download PDF
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Methodology Statement -->
    <section class="statement-section">
      <h2>Scientific Methodology Statement</h2>
      <div class="statement-box">
        <p>
          This forensic audio analysis employs methods validated in peer-reviewed literature 
          and widely accepted in the acoustic forensics community. The <strong>roughness analysis</strong> 
          follows Arnal et al.'s (2015) identification of the 30-150 Hz modulation band as the 
          biological signature of human distress. The <strong>spectral feature extraction</strong> 
          applies standards from forensic voice analysis research (Formative 2020). The 
          <strong>multi-model ensemble approach</strong> is informed by INTERSPEECH literature on 
          scream detection in noisy environments.
        </p>
        <p>
          All thresholds (roughness &gt; 20% suspicious, &gt; 40% proof; crest &gt; 15 dB; centroid 
          &gt; 1500 Hz) are derived from established acoustic forensic practice. The use of three 
          orthogonal models (VGGish, BEATs, CLAP) for triangulation follows ensemble method 
          best practices for improving detection confidence in low-SNR conditions.
        </p>
        <p class="limitation">
          <strong>Limitations:</strong> This analysis was conducted on distant, outdoor microphone 
          recordings with significant ambient noise. While the methods are scientifically sound, 
          the data quality constraints affect certainty. Results should be considered alongside 
          other evidence and expert human review.
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .page-header {
    text-align: center;
    margin-bottom: 60px;
    border-bottom: 2px solid var(--accent-red);
    padding-bottom: 30px;
  }

  .page-header h1 {
    font-size: 3rem;
    margin: 0;
    color: #fff;
  }

  .subtitle {
    color: var(--accent-cyan);
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    margin-top: 10px;
  }

  .lead {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--text-main);
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
  }

  h2 {
    color: var(--accent-cyan);
    font-family: 'JetBrains Mono', monospace;
    border-left: 4px solid var(--accent-red);
    padding-left: 20px;
    margin: 60px 0 30px 0;
  }

  .application-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin: 40px 0;
  }

  .app-card {
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 30px;
  }

  .app-card h3 {
    color: #fff;
    margin: 0 0 10px 0;
    font-size: 1.1rem;
  }

  .app-card .paper {
    color: var(--accent-cyan);
    font-size: 0.85rem;
    font-style: italic;
    margin: 0 0 15px 0;
  }

  .app-card .desc {
    color: var(--text-main);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 20px 0;
  }

  .app-card .threshold {
    background: rgba(0,240,255,0.05);
    padding: 15px;
    border-radius: 4px;
    border-left: 3px solid var(--accent-cyan);
    color: var(--text-dim);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .section-note {
    color: var(--text-dim);
    font-style: italic;
    margin-bottom: 30px;
  }

  .ref-list {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .ref-item {
    display: flex;
    gap: 25px;
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 30px;
  }

  .ref-number {
    font-size: 2rem;
    font-weight: bold;
    color: var(--accent-red);
    font-family: 'JetBrains Mono', monospace;
    opacity: 0.5;
    min-width: 50px;
  }

  .ref-content {
    flex: 1;
  }

  .ref-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 10px;
  }

  .ref-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #fff;
    line-height: 1.4;
  }

  .ref-category {
    background: rgba(0,240,255,0.1);
    color: var(--accent-cyan);
    padding: 5px 12px;
    border-radius: 2px;
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  .ref-meta {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin: 0 0 15px 0;
  }

  .ref-meta .doi {
    color: var(--accent-cyan);
    font-family: 'JetBrains Mono', monospace;
    margin-left: 10px;
  }

  .ref-application {
    color: var(--text-main);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 20px 0;
  }

  .download-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--accent-red);
    border: 1px solid var(--accent-red);
    padding: 8px 16px;
    border-radius: 2px;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .download-link:hover {
    background: var(--accent-red);
    color: #000;
  }

  .download-link .icon {
    font-size: 1rem;
  }

  .statement-box {
    background: rgba(255,62,62,0.05);
    border: 1px solid rgba(255,62,62,0.2);
    padding: 40px;
    border-radius: 4px;
  }

  .statement-box p {
    color: var(--text-main);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 20px 0;
  }

  .statement-box p:last-child {
    margin-bottom: 0;
  }

  .statement-box .limitation {
    border-top: 1px solid rgba(255,62,62,0.2);
    padding-top: 20px;
    margin-top: 20px;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .application-grid {
      grid-template-columns: 1fr;
    }
    
    .ref-item {
      flex-direction: column;
      gap: 15px;
    }
    
    .ref-header {
      flex-direction: column;
    }
  }
</style>
