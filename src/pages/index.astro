---
import EvidenceCard from '../components/EvidenceCard.astro';
import TimelineViewer from '../components/TimelineViewer.astro';
import findings from '../data/findings.json';

// Filter for-sures to handle grouping
const forSures = findings.filter(f => f.is_forsure);
const others = findings.filter(f => !f.is_forsure);
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>1112 KING RD | FORENSIC AUDIO ANALYSIS</title>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --bg: #050505;
        --card-bg: rgba(20, 20, 20, 0.8);
        --accent-red: #ff3e3e;
        --accent-yellow: #ffb800;
        --accent-cyan: #00f0ff;
        --text-main: #e0e0e0;
        --text-dim: #808080;
        --border: #2a2a2a;
      }

      body {
        background: var(--bg);
        color: var(--text-main);
        font-family: 'Outfit', sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        background-image: 
          linear-gradient(rgba(255, 62, 62, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 62, 62, 0.03) 1px, transparent 1px);
        background-size: 50px 50px;
      }

      .glitch {
        position: relative;
        display: inline-block;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: -2px;
      }

      .glitch::before,
      .glitch::after {
        content: attr(data-text);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--bg);
      }

      .glitch::before {
        left: 2px;
        text-shadow: -2px 0 var(--accent-cyan);
        clip: rect(44px, 450px, 56px, 0);
        animation: glitch-anim 5s infinite linear alternate-reverse;
      }

      .glitch::after {
        left: -2px;
        text-shadow: -2px 0 var(--accent-red);
        clip: rect(12px, 450px, 34px, 0);
        animation: glitch-anim 5s infinite linear alternate-reverse;
      }

      @keyframes glitch-anim {
        0% { clip: rect(12px, 9999px, 45px, 0); }
        20% { clip: rect(67px, 9999px, 89px, 0); }
        40% { clip: rect(34px, 9999px, 56px, 0); }
        60% { clip: rect(12px, 9999px, 23px, 0); }
        80% { clip: rect(56px, 9999px, 78px, 0); }
        100% { clip: rect(23px, 9999px, 45px, 0); }
      }

      .container { max-width: 1100px; margin: 0 auto; padding: 60px 20px; }
      
      header { margin-bottom: 80px; border-left: 4px solid var(--accent-red); padding-left: 30px; }
      header h1 { font-size: 4rem; margin: 0; line-height: 0.9; }
      .tagline { color: var(--accent-red); font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; margin-top: 10px; letter-spacing: 4px; }
      .triangulation-link { display: inline-block; margin-top: 20px; color: var(--accent-cyan); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; border: 1px solid var(--accent-cyan); padding: 10px 20px; border-radius: 2px; transition: all 0.2s; }
      .triangulation-link:hover { background: var(--accent-cyan); color: #000; }

      .section-label {
        font-family: 'JetBrains Mono', monospace;
        font-weight: bold;
        color: var(--accent-cyan);
        text-transform: uppercase;
        letter-spacing: 5px;
        margin-bottom: 30px;
        display: block;
        border-bottom: 1px solid var(--border);
        padding-bottom: 10px;
      }
      
      .section-header {
        margin-bottom: 40px;
        padding: 20px;
        border-radius: 4px;
        background: rgba(255, 184, 0, 0.05);
        border: 1px solid rgba(255, 184, 0, 0.2);
      }
      .section-header.yellow { border-left: 4px solid var(--accent-yellow); }
      .section-header.red { border-left: 4px solid var(--accent-red); }
      .section-desc {
        color: var(--text-dim);
        font-size: 0.95rem;
        margin: 15px 0 0 0;
        font-style: italic;
      }
      .background-section {
        margin-top: 100px;
        padding-top: 60px;
        border-top: 2px dashed var(--border);
      }

      .stats-bar {
        display: flex; gap: 40px; margin-bottom: 60px;
        background: var(--card-bg); border: 1px solid var(--border);
        padding: 20px 40px; border-radius: 4px;
        backdrop-filter: blur(10px);
      }
      .stat-item { display: flex; flex-direction: column; }
      .stat-val { font-size: 1.5rem; font-weight: bold; color: #fff; }
      .stat-label { font-size: 0.7rem; text-transform: uppercase; color: var(--text-dim); letter-spacing: 2px; }

      .references {
        margin-top: 100px; padding: 40px; background: rgba(0, 240, 255, 0.03);
        border: 1px solid rgba(0, 240, 255, 0.2); border-radius: 8px;
      }
      .references h2 { color: var(--accent-cyan); margin-top: 0; font-family: 'JetBrains Mono', monospace; }
      .ref-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin: 30px 0; }
      .ref-item { background: rgba(0,0,0,0.3); padding: 20px; border-radius: 4px; border-left: 3px solid var(--accent-cyan); }
      .ref-item h3 { color: var(--accent-cyan); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; margin-top: 0; }
      .ref-item p { margin: 8px 0; font-size: 0.9rem; }
      .ref-item strong { color: #fff; }
      .ref-doi { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--accent-cyan); }
      .ref-note { font-size: 0.8rem; color: var(--text-dim); font-style: italic; }
      .ref-footer { text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(0,240,255,0.2); font-style: italic; color: var(--text-dim); }
      
      .methodology {
        margin-top: 60px; padding: 40px; background: rgba(255, 62, 62, 0.03);
        border: 1px solid rgba(255, 62, 62, 0.2); border-radius: 8px;
      }
      .methodology h2 { color: var(--accent-red); margin-top: 0; font-family: 'JetBrains Mono', monospace; }
      .method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin: 30px 0; }
      .method-item { background: rgba(0,0,0,0.3); padding: 20px; border-radius: 4px; border-left: 3px solid var(--accent-red); }
      .method-item h3 { color: var(--accent-cyan); font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; margin-top: 0; }
      .method-item p { font-size: 0.9rem; color: var(--text-dim); margin: 0; }
      .thresholds { background: rgba(0,0,0,0.3); padding: 20px; border-radius: 4px; margin-top: 20px; }
      .thresholds h4 { color: var(--accent-yellow); font-family: 'JetBrains Mono', monospace; margin-top: 0; }
      .thresholds ul { margin: 0; padding-left: 20px; color: var(--text-dim); font-size: 0.9rem; }
      .thresholds li { margin-bottom: 8px; }
      
      .glossary {
        margin-top: 60px; padding: 40px; background: rgba(0, 240, 255, 0.05);
        border: 1px solid rgba(0, 240, 255, 0.2); border-radius: 8px;
        font-family: 'JetBrains Mono', monospace;
      }
      .glossary h2 { font-size: 1.2rem; color: var(--accent-cyan); margin-top: 0; }
      .glossary dl { display: grid; grid-template-columns: 150px 1fr; gap: 20px; }
      .glossary dt { font-weight: bold; color: #fff; }
      .glossary dd { margin: 0; color: var(--text-dim); font-size: 0.9rem; }
    </style>
</head>
<body>
    <nav style="background: rgba(0,0,0,0.8); border-bottom: 1px solid var(--border); padding: 20px 40px; position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px);">
      <div style="max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
        <a href="/" style="color: var(--accent-red); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-weight: bold; font-size: 1.2rem;">1112 KING RD</a>
        <div style="display: flex; gap: 30px;">
          <a href="/" style="color: var(--accent-cyan); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">EVIDENCE</a>
          <a href="/triangulation" style="color: var(--text-dim); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">TRIANGULATION</a>
        </div>
      </div>
    </nav>
    <div class="container">
      <header>
        <h1 class="glitch" data-text="FORENSIC REPORT">FORENSIC REPORT</h1>
        <p class="tagline">02:00:00 - 03:00:00 AM | TARGETED ANALYSIS</p>
        <a href="/triangulation" class="triangulation-link">→ View Multi-Model Triangulation Analysis</a>
      </header>

      <!-- Interactive Timeline: 2:42 AM Sequence -->
      <TimelineViewer />

      <div class="stats-bar">
        <div class="stat-item">
          <span class="stat-val">{findings.length}</span>
          <span class="stat-label">Total Events</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">{forSures.length}</span>
          <span class="stat-label">Confirmed "For-Sures"</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">{findings.length - forSures.length}</span>
          <span class="stat-label">Background Events</span>
        </div>
      </div>

      <section id="for-sures">
        <span class="section-label">Verified Distress Markers</span>
        {forSures.length > 0 ? (
          forSures.map(finding => (
            <EvidenceCard finding={finding} />
          ))
        ) : (
          <p style="color: grey;">No confirmed markers found in this sequence.</p>
        )}
      </section>

      <section id="background" class="background-section">
        <div class="section-header yellow">
          <span class="section-label">Analyzed & Ruled Out</span>
          <p class="section-desc">{others.length} events were detected, analyzed, and determined NOT to meet the threshold for biological distress. These are included for transparency and peer review.</p>
        </div>
        {others.map(finding => (
          <EvidenceCard finding={finding} />
        ))}
      </section>

      <section class="references">
        <h2>PEER-REVIEWED RESEARCH</h2>
        <div class="ref-grid">
          <div class="ref-item">
            <h3>Primary: Acoustic Roughness</h3>
            <p><strong>"Human Screams Occupy a Privileged Niche in the Communication Soundscape"</strong></p>
            <p>Arnal et al., Current Biology (2015)</p>
            <p class="ref-doi">DOI: 10.1016/j.cub.2015.06.010</p>
            <p class="ref-note">Establishes the 30-150 Hz modulation band as the biological signature of human distress.</p>
          </div>
          <div class="ref-item">
            <h3>AI: Emotion Recognition</h3>
            <p><strong>Wav2Vec 2.0 Framework</strong></p>
            <p>Baevski et al., arXiv (2020)</p>
            <p class="ref-doi">arXiv:2006.11477</p>
            <p class="ref-note">Self-supervised learning for speech emotion classification.</p>
          </div>
          <div class="ref-item">
            <h3>Dataset: RAVDESS</h3>
            <p><strong>Ryerson Audio-Visual Database of Emotional Speech and Song</strong></p>
            <p>PLOS ONE (2018)</p>
            <p class="ref-doi">DOI: 10.1371/journal.pone.0196391</p>
            <p class="ref-note">Training dataset for emotional speech recognition.</p>
          </div>
        </div>
        <p class="ref-footer">All acoustic findings fall within the 30-150 Hz "privileged niche" identified by Arnal as unique to biological distress.</p>
      </section>

      <section class="methodology">
        <h2>SCIENTIFIC METHODOLOGY</h2>
        <div class="method-grid">
          <div class="method-item">
            <h3>01 // ACOUSTIC ROUGHNESS</h3>
            <p>Based on <strong>Luc Arnal et al., Current Biology (2015)</strong>. We extract the amplitude envelope via Hilbert transform and compute Power Spectral Density (PSD). The 30-150 Hz modulation band corresponds to physical limits of human vocal cords under extreme subglottal pressure. Signals with >20% modulation energy in this band indicate biological distress; >40% is forensic proof of terror screaming.</p>
          </div>
          <div class="method-item">
            <h3>02 // CREST FACTOR ANALYSIS</h3>
            <p>Crest Factor measures peak-to-RMS amplitude ratio. Physical impacts (doors, heavy objects) produce sharp vertical spikes (>15 dB) with sudden onsets. We use this to identify catalyst events that precede distress responses.</p>
          </div>
          <div class="method-item">
            <h3>03 // SPECTRAL CENTROID & CHAOS</h3>
            <p><strong>Spectral Centroid</strong> tracks brightness center—shrieks range 1500-3500 Hz, significantly higher than conversation. <strong>Spectral Flatness</strong> measures chaos vs tonality. Biological screams are inherently noisy (high flatness) compared to mechanical or electronic sources.</p>
          </div>
          <div class="method-item">
            <h3>04 // AI EMOTION TRIANGULATION</h3>
            <p>We hit each timestamp with 3 distinct analytical lenses: (1) Wav2Vec2 emotion classification for biological markers, (2) Arnal roughness analysis for physical properties, (3) Spectral chaos/crest for impulse detection. When all three return positive, the event graduates to FOR-SURE status.</p>
          </div>
        </div>
        <div class="thresholds">
          <h4>FORENSIC THRESHOLDS</h4>
          <ul>
            <li><strong>Roughness > 20%</strong> = Suspicious (biological distress)</li>
            <li><strong>Roughness > 40%</strong> = Forensic proof of terror scream</li>
            <li><strong>Crest > 15 dB</strong> = Physical impact/mechanical</li>
            <li><strong>Centroid > 1500 Hz</strong> = High-pitch shriek</li>
            <li><strong>Flatness > 15%</strong> = Chaotic/non-tonal</li>
          </ul>
        </div>
      </section>

      <section class="glossary">
        <h2>THE FOUR FORENSIC INDICATORS</h2>
        <dl>
          <dt>IMAGE 01: BRICK (Waveform)</dt>
          <dd><strong>Raw Sound Pressure.</strong> A "Brick" shape proves sustained energy. Terror screams don't just "pop"—they hold. We use this to identify sudden impacts vs sustained vocalization.</dd>
          
          <dt>IMAGE 02: MESS (Spectrogram)</dt>
          <dd><strong>Frequency Over Time.</strong> We look for "Frequency Blur"—distant, muffled screams lose clarity but leave a blur of high-frequency energy that normal background noise doesn't produce.</dd>
          
          <dt>IMAGE 03: SHRED (Chaos Score)</dt>
          <dd><strong>Spectral Flatness.</strong> The "Shred Score." Most sounds are tonal (whistles, words). Screams are noisy and chaotic. High shred = physically rough = biological distress.</dd>
          
          <dt>IMAGE 04: SHRIEK (Pitch Track)</dt>
          <dd><strong>Spectral Centroid.</strong> Tracks the "center" of the sound. When pitch spikes into 1500-2000Hz range, it's a shriek. Human vocal cords under adrenaline produce this signature.</dd>
        </dl>
      </section>
    </div>

    <script>
      import WaveSurfer from 'wavesurfer.js';
      
      document.querySelectorAll('.play-btn').forEach(btn => {
        const id = btn.dataset.id;
        const url = btn.dataset.url;
        
        const ws = WaveSurfer.create({
          container: `#waveform-${id}`,
          waveColor: '#333',
          progressColor: '#ff3e3e',
          cursorColor: '#fff',
          barWidth: 2,
          height: 60,
          url: url
        });

        btn.addEventListener('click', () => {
          ws.playPause();
          btn.textContent = ws.isPlaying() ? 'PAUSE' : 'PLAY EVIDENCE';
        });

        ws.on('finish', () => {
          btn.textContent = 'PLAY EVIDENCE';
        });
      });
    </script>
</body>
</html>
