---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | 1112 King Rd">
  <div class="container">
    <header class="page-header">
      <h1 class="glitch" data-text="CONTACT">CONTACT</h1>
      <p class="subtitle">Questions About This Analysis</p>
    </header>

    <section class="contact-section">
      <div class="contact-card">
        <h2>Get In Touch</h2>
        <p class="intro">
          This analysis was conducted by a citizen researcher using publicly available 
          AI models and forensic audio techniques. For questions about the methodology, 
          data, or findings:
        </p>

        <div class="contact-methods">
          <a href="https://discord.com/users/flintx.10" target="_blank" rel="noopener noreferrer" class="contact-link discord">
            <div class="icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
            </div>
            <div class="info">
              <span class="label">Discord</span>
              <span class="handle">flintx.10</span>
            </div>
          </a>

          <a href="https://t.me/Saulgoodman2023" target="_blank" rel="noopener noreferrer" class="contact-link telegram">
            <div class="icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </div>
            <div class="info">
              <span class="label">Telegram</span>
              <span class="handle">@Saulgoodman2023</span>
            </div>
          </a>
        </div>
      </div>

      <div class="disclaimer-card">
        <h3>Important Notice</h3>
        <p>
          This is <strong>citizen forensic analysis</strong> conducted using publicly 
          available AI models and peer-reviewed methodologies. It is not official 
          law enforcement work.
        </p>
        <p>
          All data, scripts, and methodologies are provided for transparency and 
          reproducibility. This site represents independent research and analysis.
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 600px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .page-header {
    text-align: center;
    margin-bottom: 60px;
    border-bottom: 2px solid var(--accent-red);
    padding-bottom: 30px;
  }

  .page-header h1 {
    font-size: 3rem;
    margin: 0;
    color: #fff;
  }

  .subtitle {
    color: var(--accent-cyan);
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    margin-top: 10px;
  }

  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .contact-card {
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 40px;
  }

  .contact-card h2 {
    color: #fff;
    margin: 0 0 20px 0;
    font-size: 1.5rem;
  }

  .intro {
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 30px;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .contact-link:hover {
    background: rgba(255,255,255,0.06);
    border-color: var(--accent-cyan);
  }

  .contact-link.discord:hover {
    border-color: #5865F2;
  }

  .contact-link.telegram:hover {
    border-color: #0088cc;
  }

  .icon {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon svg {
    width: 40px;
    height: 40px;
  }

  .discord .icon {
    color: #5865F2;
  }

  .telegram .icon {
    color: #0088cc;
  }

  .info {
    display: flex;
    flex-direction: column;
  }

  .label {
    color: var(--text-dim);
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .handle {
    color: #fff;
    font-size: 1.3rem;
    font-weight: bold;
    font-family: 'JetBrains Mono', monospace;
  }

  .disclaimer-card {
    background: rgba(255,184,0,0.05);
    border: 1px solid rgba(255,184,0,0.2);
    border-radius: 4px;
    padding: 30px;
  }

  .disclaimer-card h3 {
    color: var(--accent-yellow);
    margin: 0 0 15px 0;
    font-size: 1.1rem;
  }

  .disclaimer-card p {
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0 0 15px 0;
  }

  .disclaimer-card p:last-child {
    margin-bottom: 0;
  }
</style>
