---
import Layout from '../layouts/Layout.astro';

const scripts = [
  {
    name: "vggish_analysis.py",
    title: "VGGish Acoustic Activation Analysis",
    model: "VGGish",
    description: "Extracts 128-dimensional embeddings from audio and computes activation norms to detect acoustic salience peaks.",
    requirements: ["tensorflow", "tensorflow_hub", "numpy", "matplotlib", "scipy"],
    inputs: "WAV files (16kHz mono)",
    outputs: "PNG plots with activation peaks marked",
    code: `import tensorflow as tf
import tensorflow_hub as hub
import numpy as np
import matplotlib.pyplot as plt
from scipy.io import wavfile

# Load VGGish from TensorFlow Hub
model = hub.load('https://tfhub.dev/google/vggish/1')

# Process audio
sr, wav_data = wavfile.read(clip_path)
if len(wav_data.shape) > 1:
    wav_data = np.mean(wav_data, axis=1)

# Extract embeddings (128-dim per 0.96s window)
embeddings = model(wav_data)
norms = np.linalg.norm(embeddings, axis=1)

# Find peak activation
peak_frame = np.argmax(norms)
peak_time = peak_frame * 0.96  # VGGish hop size`
  },
  {
    name: "beats_analysis.py", 
    title: "BEATs Deep Anomaly Detection",
    model: "BEATs",
    description: "Uses Microsoft's self-supervised transformer to extract 768-dimensional embeddings and detect structural anomalies.",
    requirements: ["torch", "torchaudio", "numpy", "pandas", "matplotlib"],
    inputs: "WAV files (resampled to 16kHz)",
    outputs: "Activation plots + CSV of detected spikes",
    code: `import torchaudio
import torch
import numpy as np
from beats_trainer import BEATsFeatureExtractor

# Initialize BEATs model
extractor = BEATsFeatureExtractor()
beats_model = extractor.model
beats_model.eval()

# Extract features
waveform, sr = torchaudio.load(filepath)
output = beats_model.extract_features(waveform)
embeds = output[0].squeeze(0).cpu().numpy()

# Compute activation (mean abs of 768-dim embeddings)
activation = np.mean(np.abs(embeds), axis=1)

# Detect spikes above threshold
mean_a = np.mean(activation)
std_a = np.std(activation)
thresh = mean_a + 1.8 * std_a
spike_mask = activation > thresh`
  },
  {
    name: "laionclap_analysis.py",
    title: "LAION-CLAP Semantic Matching",
    model: "LAION-CLAP", 
    description: "Zero-shot text-to-audio matching using contrastive learning. Scores audio against text descriptions.",
    requirements: ["transformers", "torch", "librosa", "numpy", "matplotlib"],
    inputs: "WAV files + text query list",
    outputs: "Similarity heatmap (cosine similarity scores)",
    code: `from transformers import ClapModel, ClapProcessor
import librosa
import numpy as np

# Load LAION-CLAP
model = ClapModel.from_pretrained("laion/clap-htsat-unfused")
processor = ClapProcessor.from_pretrained("laion/clap-htsat-unfused")

# Text descriptions to match
text_descriptions = [
    "loud male voice saying stop urgently",
    "woman screaming in terror",
    "mechanical impact bang",
    # ... (21 total queries)
]

# Process audio chunks
inputs = processor(text=text_descriptions, audio=[chunk], 
                   return_tensors="pt", sampling_rate=48000)

# Get cosine similarity
audio_emb = outputs.audio_embeds
audio_emb = audio_emb / audio_emb.norm(dim=-1, keepdim=True)
text_emb = outputs.text_embeds  
text_emb = text_emb / text_emb.norm(dim=-1, keepdim=True)
sim = (audio_emb @ text_emb.T).squeeze().cpu().numpy()`
  }
];
---

<Layout title="Analysis Scripts | 1112 King Rd">
  <div class="container">
    <header class="page-header">
      <h1 class="glitch" data-text="ANALYSIS SCRIPTS">ANALYSIS SCRIPTS</h1>
      <p class="subtitle">Reproducible Research - Download & Rerun Our Analysis</p>
    </header>

    <section class="intro">
      <p class="lead">
        Full transparency: these are the exact scripts used to generate our findings. 
        Anyone can download them, install the requirements, and reproduce our results. 
        This is the standard for scientific reproducibility.
      </p>
      <div class="repro-box">
        <h3>Quick Reproduction Guide</h3>
        <ol>
          <li>Download the 5 audio clips from our evidence page</li>
          <li>Download these 3 scripts</li>
          <li>Install requirements: <code>pip install -r requirements.txt</code></li>
          <li>Run each script on the same audio files</li>
          <li>Compare outputs to our published results</li>
        </ol>
      </div>
    </section>

    {scripts.map((script) => (
      <section class="script-section">
        <div class="script-header">
          <div class="script-title-group">
            <span class="model-badge">{script.model}</span>
            <h2>{script.title}</h2>
          </div>
          <a 
            href={`/scripts/${script.name}`} 
            download 
            class="download-btn"
          >
            <span class="icon">↓</span>
            Download {script.name}
          </a>
        </div>

        <div class="script-content">
          <div class="script-meta">
            <div class="meta-item">
              <span class="label">Inputs:</span>
              <span class="value">{script.inputs}</span>
            </div>
            <div class="meta-item">
              <span class="label">Outputs:</span>
              <span class="value">{script.outputs}</span>
            </div>
            <div class="meta-item">
              <span class="label">Requirements:</span>
              <span class="value">{script.requirements.join(", ")}</span>
            </div>
          </div>

          <p class="script-desc">{script.description}</p>

          <div class="code-block">
            <div class="code-header">
              <span class="filename">{script.name}</span>
              <span class="lang">Python</span>
            </div>
            <pre><code>{script.code}</code></pre>
          </div>
        </div>
      </section>
    ))}

    <section class="requirements-section">
      <h2>Complete Requirements</h2>
      <div class="req-box">
        <p>Save this as <code>requirements.txt</code> and run <code>pip install -r requirements.txt</code>:</p>
        <pre><code>tensorflow>=2.8.0
tensorflow-hub>=0.12.0
torch>=1.10.0
torchaudio>=0.10.0
transformers>=4.20.0
librosa>=0.9.0
numpy>=1.21.0
matplotlib>=3.5.0
scipy>=1.7.0
pandas>=1.3.0
tqdm>=4.62.0</code></pre>
      </div>
    </section>

    <section class="verification-section">
      <h2>Verification Statement</h2>
      <div class="verify-box">
        <p>
          These scripts represent the <strong>exact code</strong> used to generate the 
          findings presented on this site. No post-processing, no cherry-picking, no 
          hidden steps. What you see is what was run.
        </p>
        <p>
          If you run these scripts on the same audio files, you should get:
        </p>
        <ul>
          <li>VGGish: Same peak times (±0.96s resolution) and activation values</li>
          <li>BEATs: Same spike detection with 1.8σ threshold</li>
          <li>CLAP: Same similarity heatmaps (±chunking variance)</li>
        </ul>
        <p class="note">
          Minor variations may occur due to:
          - Random initialization in some model layers
          - Floating point precision differences across hardware
          - Version differences in dependencies
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
